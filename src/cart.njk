                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="block-cart-bottom">
                        <div class="promocode">
                            <input autocomplete="off" type="text" name="form[]" placeholder="Введите промокод">
                            <button type="button" class="promocode__button">
                                Применить
                            </button>
                        </div>
                        <div class="block-cart-bottom__totals">
                            <div class="block-cart-bottom__total">
                                <span class="desc">ИТОГО К ОПЛАТЕ</span>
                                <span class="mob">ИТОГО</span>
                                <div class="block-cart-bottom__price">
                                    59400 ₽
                                </div>
                            </div>
                            <div class="block-cart-bottom__sales">
                                <span>Скидка</span>
                                <div class="block-cart-bottom__sale">
                                    - 2400 ₽
                                </div>
                            </div>
                        </div>
                        <a href="./" class="btn">
                            <span>Оформить заказ</span>
                        </a>
                    </div>
                </div>
