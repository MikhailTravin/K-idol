<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Корзина</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header.njk' %}
        <main class="main">

            <div class="block-cart">
                <div class="container">
                    <div class="block-cart__heading-complex">
                        <div class="breadcrumbs">
                            <ul>
                                <li>
                                    <a href="#">
                                        Главная
                                        <svg aria-hidden="true" width="23" height="8">
                                            <use xlink:href="img/sprite.svg#arrow2"></use>
                                        </svg>
                                    </a>
                                </li>
                                <li><span>Разное</span></li>
                            </ul>
                        </div>
                        <h2 class="title2">Корзина</h2>
                    </div>
                    <div class="block-cart-top">
                        <div class="search">
                            <input autocomplete="off" type="text" name="form[]" placeholder="Фильтр">
                            <div class="search__button">
                                <img src="img/icons/search.svg" alt="">
                            </div>
                        </div>
                        <div class="block-cart-top__buttons">
                            <div class="block-cart-top__title">В корзине 4 товара</div>
                            <button type="button" class="block-cart-top__delete">
                                <svg aria-hidden="true" width="11" height="11">
                                    <use xlink:href="img/sprite.svg#close"></use>
                                </svg>
                                <span>Очистить корзину</span>
                            </button>
                        </div>
                    </div>
                    <div class="block-cart-tables">
                        <div class="block-cart-tables__table">
                            <div class="block-cart-tables__left">
                                <a href="./" class="block-cart-tables__image">
                                    <img src="img/products/image15.webp" alt="">
                                </a>
                                <div class="block-cart-tables__item">
                                    <a href="./" class="block-cart-tables__title">
                                        Название продукта может
                                        быть в 2 строки
                                    </a>
                                    <ul>
                                        <li>
                                            <span>Вес / г.</span> 12
                                        </li>
                                        <li>
                                            <span>Цвет</span>
                                            <div style="background: #f1d6be;" class="block-cart-tables__color"></div>
                                            Natural Beige
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div class="block-cart-tables__right">
                                <div class="block-cart-tables__prices">
                                    <div class="block-cart-tables__old-price">2700 ₽</div>
                                    <div class="block-cart-tables__price">1400 ₽</div>
                                </div>
                                <div class="block-cart-tables__quantity">
                                    <div data-quantity class="quantity">
                                        <button data-quantity-plus type="button"
                                            class="quantity__button quantity__button_plus">
                                            <svg aria-hidden="true" width="9" height="9">
                                                <use xlink:href="img/sprite.svg#plus"></use>
                                            </svg>
                                        </button>
                                        <div class="quantity__input">
                                            <input data-quantity-value autocomplete="off" type="text" name="form[]"
                                                value="1">
                                        </div>
                                        <button data-quantity-minus type="button"
                                            class="quantity__button quantity__button_minus">
                                            <svg aria-hidden="true" width="9" height="2">
                                                <use xlink:href="img/sprite.svg#minus"></use>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="block-cart-tables__col">шт.</div>
                                </div>
                                <div class="block-cart-tables__price">1400 ₽</div>
                                <div class="block-cart-tables__delete">
                                    <img src="img/icons/delete.svg" alt="">
