<div class="block-forms">
    <div class="container">
        <div class="block-forms__circle"></div>
        <div class="block-forms__content">
            <img loading="lazy" src="img/image1.webp" alt="" class="block-forms__pic1">
            <form action="#" class="form">
                <div class="form__title">
                    Вопросы / предложения
                    <span>콘택트 렌즈</span>
                </div>
                <div class="form__inputs">
                    <div class="form__input">
                        <input autocomplete="off" type="text" name="form[]" placeholder="Ваше имя" class="input">
                    </div>
                    <div class="form__input">
                        <input data-required="email" autocomplete="off" type="text" name="form[]" placeholder="Почта"
                            class="input">
                    </div>
                    <div class="form__input">
                        <textarea placeholder="Сообщение" class="input textarea"></textarea>
                    </div>
                </div>
                <div class="form__bottom">
                    <label class="checkbox">
                        <input data-required class="checkbox__input" type="checkbox" value="1" name="form[]">
                        <span class="checkbox__label">
                            <span class="checkbox__icon">
                                <svg aria-hidden="true" width="16" height="12">
                                    <use xlink:href="img/sprite.svg#check1"></use>
                                </svg>
                            </span>
                            <span class="checkbox__text">
                                <a href="./">Политика хранения<br> персональных данных</a>
                            </span>
                        </span>
                    </label>
                    <button type="submit" class="btn">
                        <span>Отправить</span>
                        <svg aria-hidden="true" width="17" height="17">
                            <use xlink:href="img/sprite.svg#star1"></use>
                        </svg>
                    </button>
                </div>
            </form>
            <div class="block-forms__logo">
                <img loading="lazy" src="img/icons/logo2.svg" alt="">
            </div>
            <div class="block-forms__right">
                <div class="block-forms__titles">
                    <div class="block-forms__title">Задать вопрос
                        в Телеграм</div>
                    <p>
                        проконсультируем, подскажем
                        по срокам, стоимости и поможем принять правильное решение
                    </p>
                </div>
                <a href="./" class="btn mini"><span>Перейти в Telegram</span></a>
            </div>
        </div>
    </div>
</div>